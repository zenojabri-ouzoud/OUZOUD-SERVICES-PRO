# ==================== VÉRIFICATION DE L'INTÉGRITÉ DES DONNÉES ====================
def verify_data_integrity():
    """
    Vérifie l'intégrité des données entre les tables
    Returns:
        Dictionnaire des problèmes détectés
    """
    issues = {}
    
    # Vérifier que les produits vendus existent dans le stock
    df_ventes = get_df("ventes")
    df_stock = get_df("stock")
    
    if not df_ventes.empty and not df_stock.empty:
        produits_vendus = df_ventes['Nom'].unique() if 'Nom' in df_ventes.columns else []
        produits_stock = df_stock['Nom'].unique() if 'Nom' in df_stock.columns else []
        
        # Produits vendus mais pas dans le stock (vente libre)
        missing = set(produits_vendus) - set(produits_stock)
        if missing:
            issues['produits_orphelins'] = list(missing)
    
    # Vérifier les crédits sans paiements
    df_credits = get_df("credits")
    df_paiements = get_df("paiements_credits")
    
    if not df_credits.empty and not df_paiements.empty:
        credits_ids = df_credits['id'].unique() if 'id' in df_credits.columns else []
        paiements_credit_ids = df_paiements['Credit_ID'].unique() if 'Credit_ID' in df_paiements.columns else []
        
        # Crédits sans aucun paiement
        no_payments = set(credits_ids) - set(paiements_credit_ids)
        # Ce n'est pas un problème, juste une information
        issues['credits_sans_paiement'] = len(no_payments)
    
    return issues

