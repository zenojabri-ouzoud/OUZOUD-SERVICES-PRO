def calculate_daily_profit():
    """
    Calcule le profit quotidien (ventes + impressions)
    Returns:
        Tuple (total_ventes, total_impressions, total_general)
    """
    today = datetime.now().strftime('%d/%m/%Y')
    df_v = get_df("ventes")
    df_i = get_df("impressions")
    
    # Filtrer pour aujourd'hui
    ventes_today = df_v[df_v['Date'].str.contains(today, na=False)] if not df_v.empty and 'Date' in df_v.columns else pd.DataFrame()
    impressions_today = df_i[df_i['Date'].str.contains(today, na=False)] if not df_i.empty and 'Date' in df_i.columns else pd.DataFrame()
    
    total_v = ventes_today['Total'].sum() if not ventes_today.empty and 'Total' in ventes_today.columns else 0
    total_i = impressions_today['Total'].sum() if not impressions_today.empty and 'Total' in impressions_today.columns else 0
    
    return total_v, total_i, total_v + total_i

def get_top_products(limit=5):
    """
    Retourne les produits les plus vendus
    Args:
        limit: Nombre de produits à retourner
    Returns:
        DataFrame des produits les plus vendus
    """
    df_v = get_df("ventes")
    if not df_v.empty and 'Nom' in df_v.columns and 'Quantité' in df_v.columns:
        top = df_v.groupby('Nom')['Quantité'].sum().sort_values(ascending=False).head(limit)
        return top
    return pd.DataFrame()

def get_low_stock_alerts():
    """
