# ==================== CONFIGURATION SUPABASE ====================
# Connexion à la base de données Supabase
# Les identifiants sont stockés dans les secrets Streamlit

try:
    supabase: Client = create_client(
        st.secrets["supabase_url"],
        st.secrets["supabase_key"]
    )
    # Si la connexion réussit, on continue
    print("✅ Connexion Supabase établie avec succès!")
except Exception as e:
    # Si la connexion échoue, on affiche l'erreur et on arrête tout
    st.error(f"❌ Erreur de connexion à Supabase: {e}")
    st.error("Vérifiez vos secrets dans .streamlit/secrets.toml")
    st.stop()

