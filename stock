def auto_backup():
    """
    Crée une sauvegarde automatique de toutes les tables
    Returns:
        Bytes du fichier Excel
    """
    tables = [
        "stock", "ventes", "impressions", "credits",
        "paiements_credits", "commandes", "historique_caisse"
    ]
    
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        for table in tables:
            df = get_df(table)
            if not df.empty:
                df.to_excel(writer, sheet_name=table, index=False)
    
    output.seek(0)
    return output.getvalue()

